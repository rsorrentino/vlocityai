# Environment Configuration Template
# Copy this file to .env and update the values

NODE_ENV=development
PORT=3001

# Database Configuration
DATABASE_URL=postgresql://postgres:password@localhost:5432/vlocity_manager
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vlocity_manager
DB_USER=postgres
DB_PASSWORD=password
DB_SCHEMA=vlocity_datapack_manager
REDIS_URL=redis://localhost:6379

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=24h
BCRYPT_ROUNDS=12

# Salesforce Configuration
SFDX_USERNAME=your.username@company.com
SOURCE_SFDX_USERNAME=your.source@company.com
TARGET_SFDX_USERNAME=your.target@company.com

# Vlocity Configuration
VLOCITY_VERSION=1.17.12
VLOCITY_TIMEOUT=300000

# Security
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Logging
LOG_LEVEL=info
LOG_MAX_SIZE=5242880
LOG_MAX_FILES=5

# File Upload
MAX_FILE_SIZE=50mb
UPLOAD_PATH=./uploads

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090

# Enterprise Features (Enabled by Default)
ENABLE_ENTERPRISE_MONITORING=true
ENABLE_AUDIT_LOGGING=true
ENABLE_ENTERPRISE_JOB_QUEUE=true

# Audit Configuration
AUDIT_RETENTION_DAYS=365
AUDIT_BATCH_SIZE=100

# Job Queue Configuration
MAX_CONCURRENT_JOBS=10
MAX_JOBS_PER_USER=5
MAX_JOBS_PER_TENANT=20

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# AI Chat Adapters
# Server-side fallback keys (users can also supply their own via the UI)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GITHUB_TOKEN=
OLLAMA_BASE_URL=http://localhost:11434

# Default adapter shown to new users
DEFAULT_AI_ADAPTER=anthropic
DEFAULT_AI_MODEL=claude-sonnet-4-6