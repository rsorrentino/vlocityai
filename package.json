{
  "name": "vlocity-datapack-manager",
  "version": "1.0.0",
  "description": "Modern Node.js application for managing Vlocity DataPack exports and deployments",
  "main": "server/index.js",
  "scripts": {
    "start": "node --max-http-header-size=32768 server/index.js",
    "prestart": "service redis-server start 2>/dev/null || sudo -n service redis-server start 2>/dev/null || true",
    "dev": "nodemon --exec \"node --max-http-header-size=32768\" server/index.js",
    "predev": "service redis-server start 2>/dev/null || sudo -n service redis-server start 2>/dev/null || true",
    "build": "cd client && npm run build",
    "install-client": "cd client && npm install",
    "install-server": "cd server && npm install",
    "dev-full": "node scripts/dev-full-auto-ports.js",
    "client-dev": "cd client && npm start",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:unit": "jest --testPathPattern=__tests__/services",
    "test:integration": "jest --testPathPattern=__tests__/integration",
    "test:routes": "jest --testPathPattern=__tests__/routes",
    "test:verbose": "jest --verbose --coverage",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "test:e2e": "playwright test",
    "test:load": "artillery run tests/load/load-test.yml",
    "test:enterprise": "jest --testPathPattern=__tests__/enterprise",
    "test-properties": "node shared/test-properties.js",
    "lint": "eslint server/ client/src/",
    "format": "prettier --write server/ client/src/",
    "install-vlocity": "npm install -g vlocity",
    "install-sfdx": "npm install -g @salesforce/cli",
    "install-cli-tools": "npm run install-vlocity && npm run install-sfdx",
    "check-vlocity": "vlocity --version",
    "db:migrate": "sequelize-cli db:migrate",
    "db:migrate:undo": "sequelize-cli db:migrate:undo",
    "db:migrate:status": "sequelize-cli db:migrate:status",
    "check-sfdx": "sfdx --version",
    "check-cli-tools": "npm run check-vlocity && npm run check-sfdx",
    "setup": "npm install && npm run install-client && npm run install-cli-tools",
    "install-vlocity-windows": "powershell -ExecutionPolicy Bypass -File install-vlocity-cli-windows.ps1",
    "install-postgresql-windows": "powershell -ExecutionPolicy Bypass -File install-postgresql-windows.ps1",
    "install-all-windows": "npm run install-vlocity-windows && npm run install-postgresql-windows",
    "create-users": "node scripts/create-default-users.js",
    "migrate-schema": "node scripts/migrate-to-schema.js",
    "migrate-job-context": "node scripts/migrate-job-context.js",
    "test-job-context": "node scripts/test-job-context.js",
    "migrate-job-abort-status": "node scripts/migrate-job-abort-status.js",
    "migrate-cli-type": "node scripts/migrate-cli-type.js",
    "migrate-snapshot-type": "node scripts/migrate-snapshot-job-type.js",
    "migrate-sfdmu-type": "node scripts/migrate-sfdmu-job-type.js",
    "migrate-create-orgs": "node scripts/create-orgs-table.js",
    "update-sf-references": "node scripts/update-sf-cli-references.js",
    "fix-vlocity-errors": "node scripts/fix-vlocity-errors.js",
    "clean-log-ansi": "node scripts/clean-log-ansi-codes.js",
    "test-schema": "node scripts/test-schema.js",
    "test-schema-sqlite": "node scripts/test-schema-sqlite.js",
    "setup-postgresql": "node scripts/setup-postgresql.js",
    "docs:generate": "npx mmdc -i docs/architecture/SYSTEM_ARCHITECTURE.md -o docs/images/system-architecture.png",
    "docs:generate-all": "echo Generating all diagrams... && npx mmdc -i docs/architecture/SYSTEM_ARCHITECTURE.md -o docs/images/system-architecture.png && npx mmdc -i docs/architecture/DATABASE_SCHEMA.md -o docs/images/database-schema.png && npx mmdc -i docs/workflows/AUTHENTICATION_FLOW.md -o docs/images/authentication-flow.png && npx mmdc -i docs/workflows/JOB_EXECUTION_FLOW.md -o docs/images/job-execution-flow.png && echo Diagram generation complete!",
    "postinstall": "npm run check-cli-tools || echo 'CLI tools not found - run npm run install-cli-tools to install them'"
  },
  "keywords": [
    "vlocity",
    "salesforce",
    "datapack",
    "omnistudio",
    "deployment"
  ],
  "author": "DataPack Manager Team",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.97.1",
    "@opentelemetry/api": "^1.7.0",
    "@opentelemetry/sdk-node": "^0.45.0",
    "@playwright/test": "^1.40.0",
    "@sentry/node": "^7.99.0",
    "@sentry/profiling-node": "^1.3.4",
    "adm-zip": "^0.5.10",
    "archiver": "^6.0.1",
    "artillery": "^2.0.0",
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "csv-parse": "^6.1.0",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-slow-down": "^2.0.1",
    "express-validator": "^7.0.1",
    "fs-extra": "^11.1.1",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cache": "^5.1.2",
    "node-cron": "^3.0.3",
    "openai": "^6.38.0",
    "pdfkit": "^0.14.0",
    "pg": "^8.16.3",
    "prom-client": "^15.0.0",
    "redis": "^4.6.10",
    "sequelize": "^6.37.7",
    "sequelize-cli": "^6.6.3",
    "socket.io": "^4.7.4",
    "sqlite3": "^5.0.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "unzipper": "^0.10.14",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "yaml": "^2.3.4"
  },
  "devDependencies": {
    "@mermaid-js/mermaid-cli": "^11.4.0",
    "baseline-browser-mapping": "^2.10.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.0",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  }
}
